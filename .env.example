# Sanity — copy to .env.local and fill in (also add these on Vercel)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
# Server-side read token (Viewer) — the site reads content with this
SANITY_API_READ_TOKEN=
# Write token (Editor) — only used by scripts/seed.mjs, never deployed
SANITY_WRITE_TOKEN=

# Resend (contact form) — optional
RESEND_API_KEY=
RESEND_FROM=
